/**
 * 应用正则表达式模式常量类
 * 
 * @author 2008
 * @datetime 2024/8/15 13:36
 * @className: AppPattern
 * 
 * 功能：定义应用中使用的各种正则表达式模式，主要用于文本解析、模板处理和HTML提取
 * 使用方法：通过 AppPattern.常量名 访问对应的正则表达式
 * 注意事项：这些正则表达式已预编译，可直接用于字符串匹配操作
 */
export default class AppPattern {
  /**
   * 参数模式正则表达式
   * 功能：匹配参数前的逗号或空格，但不匹配双花括号{{}}内的内容
   * 使用场景：解析函数参数时，区分参数分隔符和模板表达式
   * 正则说明：/(?<!\{\{)[ ,]\s*(?=\{)/g
   *          (?<!\{\{) - 负向后顾断言，确保前面不是{{
   *          [ ,]      - 匹配空格或逗号
   *          \s*       - 匹配0个或多个空白字符
   *          (?=\{)    - 正向前瞻断言，确保后面是{
   */
  static readonly paramPattern: RegExp = /(?<!\{\{)[ ,]\s*(?=\{)/g;

  /**
   * 通用模式正则表达式
   * 功能：匹配花括号前的逗号及周围的可选空格
   * 使用场景：解析JSON-like结构或模板参数
   * 正则说明：/\s*,\s*(?=\{)/g
   *          \s*      - 匹配0个或多个空白字符
   *          ,        - 匹配逗号
   *          \s*      - 匹配0个或多个空白字符
   *          (?=\{)   - 正向前瞻断言，确保后面是{
   */
  static readonly pattern: RegExp = /\s*,\s*(?=\{)/g;

  /**
   * 页面模式正则表达式
   * 功能：匹配尖括号<>内的内容
   * 使用场景：提取页面标识符或路由参数
   * 正则说明：/<(.*)>/
   *          <        - 匹配左尖括号
   *          (.*)     - 捕获组，匹配任意字符（贪婪模式）
   *          >        - 匹配右尖括号
   */
  static readonly pagePattern:RegExp = /<(.*)>/;

  /**
   * JavaScript代码模式正则表达式
   * 功能：匹配<js>标签内的JavaScript代码或@js:前缀的代码
   * 使用场景：提取和解析内联JavaScript代码片段
   * 正则说明：/<js>(.*?)<\/js>|@js:(.*)/i
   *          第一部分：/<js>(.*?)<\/js> - 匹配<js>标签及其内容（非贪婪模式）
   *          第二部分：@js:(.*)        - 匹配@js:前缀的代码
   *          修饰符i：不区分大小写
   */
  static readonly jsPattern: RegExp = /<js>(.*?)<\/js>|@js:(.*)/i;

  /**
   * 表达式模式正则表达式（EXP_PATTERN）
   * 功能：匹配双花括号{{}}内的表达式内容
   * 使用场景：模板引擎中提取变量或表达式
   * 正则说明：/\{\{([^\}]*?)\}\}/g
   *          \{\{      - 匹配{{
   *          ([^\}]*?) - 捕获组，非贪婪匹配任意非}字符
   *          \}\}      - 匹配}}
   *          修饰符g：全局匹配
   */
  static readonly EXP_PATTERN: RegExp = /\{\{([^\}]*?)\}\}/g;

  /**
   * 图片标签模式正则表达式
   * 功能：匹配HTML中的<img>标签并提取src属性值
   * 使用场景：从HTML内容中提取图片链接
   * 正则说明：/<img[^>]*src="([^"]*(?:"[^>]+\\})?)"[^>]*>/g
   *          <img[^>]*     - 匹配<img标签及属性（不包含>）
   *          src="         - 匹配src="
   *          ([^"]*(?:"[^>]+\\})?) - 复杂捕获组，匹配src值
   *          "[^>]*>       - 匹配闭合的"和标签结束>
   *          修饰符g：全局匹配
   */
  static readonly imgPattern: RegExp = /<img[^>]*src="([^"]*(?:"[^>]+\\})?)"[^>]*>/g;
}
