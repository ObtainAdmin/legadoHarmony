/**
 * 公共常量枚举文件 - 定义应用中使用的公共样式常量
 * 
 * 功能：提供统一的颜色、文本和图标常量，确保应用UI样式的一致性
 * 使用方法：通过 枚举名.常量名 访问对应的常量值
 * 包含三个枚举：
 *   1. PublicConstants - 公共样式常量（颜色、背景等）
 *   2. TextConstants - 文本样式常量（字体、行高、颜色等）
 *   3. ImageConstants - 图标尺寸常量
 * 注意事项：
 *   - 使用const enum定义，编译时会被替换为字面量，性能更优
 *   - 颜色值使用CSS格式（rgba或十六进制）
 *   - 尺寸值使用字符串格式，但实际是数字值
 */

/**
 * 公共样式常量枚举
 * 功能：定义应用的整体样式常量，如背景色、主题色等
 */
export const enum PublicConstants {
  /**
   * 窗口背景颜色
   * 功能：定义应用窗口的默认背景颜色
   * 使用场景：页面背景、对话框背景等
   * 颜色值：rgba(245, 245, 245, 1) - 浅灰色背景
   */
  WINDOW_BACKGROUND_COLOR = "rgba(245, 245, 245, 1)",
  
  /**
   * 整体主题颜色
   * 功能：定义应用的主题色（主色调）
   * 使用场景：按钮、链接、高亮元素等
   * 颜色值：#F60 - 橙色（RGB: 255, 102, 0）
   */
  THEME_COLOR = "#F60",

  /**
   * 白色主题颜色
   * 功能：定义白色主题颜色
   * 使用场景：浅色模式背景、卡片背景等
   * 颜色值：#ffffff - 纯白色
   */
  THEME_COLOR_WHITE = "#ffffff"
}

/**
 * 文本样式常量枚举
 * 功能：定义应用中文本相关的样式常量
 */
export const enum TextConstants {
  /**
   * 导航栏标题字体大小
   * 功能：定义导航栏标题的字体大小
   * 使用场景：页面标题、导航栏标题
   * 单位：像素（字符串格式）
   */
  TITLE_FONT_SIZE = "16",
  
  /**
   * 导航栏标题字体行高
   * 功能：定义导航栏标题的行高
   * 使用场景：控制标题文本的垂直间距
   * 单位：像素（字符串格式）
   */
  TITLE_LINE_HEIGHT = "24",
  
  /**
   * 正文字体大小
   * 功能：定义正文文本的字体大小
   * 使用场景：普通文本内容、描述文字
   * 单位：像素（字符串格式）
   */
  TEXT_FONT_SIZE = "14",
  
  /**
   * 正文字体行高
   * 功能：定义正文文本的行高
   * 使用场景：控制正文文本的垂直间距
   * 单位：像素（字符串格式）
   */
  TEXT_LINE_HEIGHT = "22",

  /**
   * 文本字体颜色
   * 功能：定义文本的默认颜色
   * 使用场景：普通文本、描述文字
   * 颜色值：rgba(0, 0, 0, 0.45) - 黑色带45%透明度（深灰色）
   */
  TEXT_FONT_COLOR = "rgba(0, 0, 0, 0.45)"
}

/**
 * 图标尺寸常量枚举
 * 功能：定义应用中图标的尺寸常量
 * 注意：此枚举与ImageConstants类功能相似但用途不同
 *       此类用于枚举常量，ImageConstants类用于类常量
 */
export const enum ImageConstants {
  /**
   * 图标标准尺寸
   * 功能：定义标准图标的尺寸
   * 使用场景：工具栏图标、按钮图标等
   * 单位：像素
   */
  icon = 24
}
