/**
 * 主题颜色项接口 - 定义主题颜色的基本结构
 * 
 * 功能：描述主题的颜色配置，包含主色和辅助色
 * 使用场景：主题颜色配置、UI颜色方案定义
 * 注意：此接口被constants/Theme.ets中的ThemeColor类使用
 */
export interface ThemeColorItem {
  /**
   * 主色（前景色）
   * 功能：主题的主要颜色，用于按钮、高亮元素、重要文本等
   * 使用场景：主要操作按钮、选中状态、强调文本
   * 格式：CSS颜色值（十六进制、RGB、RGBA等）
   * 示例："#ff6600"（橙色）、"#188bff"（蓝色）
   */
  mainColor: string;
  
  /**
   * 次色（背景色）
   * 功能：主题的辅助颜色，用于背景、次要元素等
   * 使用场景：背景色、卡片背景、次要按钮
   * 格式：CSS颜色值（十六进制、RGB、RGBA等）
   * 示例："#ffece0"（浅橙色背景）、"#e3f1ff"（浅蓝色背景）
   */
  secondColor: string;
}

/**
 * 主题项接口 - 定义完整主题项的结构（包含显示文本）
 * 
 * 功能：描述完整的主题项，包含颜色配置和显示文本
 * 使用场景：主题选择器、主题列表显示
 * 扩展：在ThemeColorItem基础上增加了text属性用于显示
 */
export interface ThemeItem {
  /**
   * 主色（前景色）
   * 功能：主题的主要颜色，用于按钮、高亮元素、重要文本等
   * 使用场景：主要操作按钮、选中状态、强调文本
   * 格式：CSS颜色值（十六进制、RGB、RGBA等）
   */
  mainColor: string;
  
  /**
   * 次色（背景色）
   * 功能：主题的辅助颜色，用于背景、次要元素等
   * 使用场景：背景色、卡片背景、次要按钮
   * 格式：CSS颜色值（十六进制、RGB、RGBA等）
   */
  secondColor: string;
  
  /**
   * 主题显示文本
   * 功能：主题的显示名称或描述
   * 使用场景：主题选择器中显示的主题名称
   * 示例："橙色主题"、"蓝色主题"、"绿色主题"
   */
  text: string;
}
