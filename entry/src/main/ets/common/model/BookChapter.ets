/**
 * 书籍章节数据模型类 - 定义小说/书籍章节的基本信息结构
 * 
 * @author 2008
 * @datetime 2024/8/25 0:11
 * @className: BookChapter
 * 
 * 功能：描述书籍章节的完整信息，包括URL、标题、位置、状态等
 * 使用场景：
 *   - 小说阅读器的章节列表
 *   - 章节内容加载和显示
 *   - 阅读进度跟踪
 *   - 章节导航和跳转
 * 特性：支持多种书籍格式（网页小说、EPUB、音频书籍等）
 */
export class BookChapter {
  /**
   * 章节地址
   * 功能：章节内容的URL地址或文件路径
   * 使用场景：加载章节内容时使用此地址获取数据
   * 默认值：空字符串
   */
  url: string = '';
  
  /**
   * 章节标题
   * 功能：章节的显示标题
   * 使用场景：章节列表显示、阅读页面标题显示
   * 默认值：空字符串
   */
  title: string = '';
  
  /**
   * 是否是卷名
   * 功能：标识此章节是否是一个卷（卷是一组章节的集合）
   * 使用场景：区分普通章节和卷标题，卷标题通常不包含实际内容
   * 默认值：false（普通章节）
   */
  isVolume: boolean = false;
  
  /**
   * 基础URL
   * 功能：用于拼接相对URL的基础地址
   * 使用场景：当章节URL是相对路径时，需要与此基础URL拼接得到完整URL
   * 默认值：空字符串
   */
  baseUrl: string = '';
  
  /**
   * 书籍地址
   * 功能：书籍的主URL或标识
   * 使用场景：标识章节所属的书籍，用于书籍切换和关联
   * 默认值：空字符串
   */
  bookUrl: string = '';
  
  /**
   * 章节序号
   * 功能：章节在书籍中的顺序编号（从0开始）
   * 使用场景：章节排序、跳转到指定章节、计算阅读进度
   * 默认值：0
   */
  index: number = 0;
  
  /**
   * 是否VIP章节
   * 功能：标识此章节是否需要VIP权限才能阅读
   * 使用场景：VIP章节提示、权限检查
   * 默认值：false（非VIP章节）
   */
  isVip: boolean = false;
  
  /**
   * 是否已购买
   * 功能：标识此章节是否已被用户购买（针对付费章节）
   * 使用场景：付费章节的购买状态检查
   * 默认值：false（未购买）
   */
  isPay: boolean = false;
  
  /**
   * 音频真实URL（可选）
   * 功能：音频书籍章节的真实音频文件URL
   * 使用场景：听书功能，播放章节对应的音频
   * 注意：仅对音频书籍有效，普通文本章节此字段为空
   */
  resourceUrl?: string;
  
  /**
   * 标签信息（可选）
   * 功能：章节的附加信息，如更新时间、字数、状态等
   * 使用场景：在章节列表中显示额外信息
   * 示例："更新于2024-08-25"、"字数：3521"
   */
  tag?: string;
  
  /**
   * 章节起始位置
   * 功能：章节在书籍文件或内容中的起始位置（字节或字符位置）
   * 使用场景：EPUB等格式书籍的精确定位
   * 默认值：0
   */
  start: number = 0;
  
  /**
   * 章节终止位置
   * 功能：章节在书籍文件或内容中的终止位置（字节或字符位置）
   * 使用场景：EPUB等格式书籍的精确定位
   * 默认值：0
   */
  end: number = 0;
  
  /**
   * EPUB书籍当前章节的fragmentId
   * 功能：EPUB格式书籍中当前章节的片段标识符
   * 使用场景：EPUB阅读器定位到特定章节
   * 默认值：空字符串
   */
  startFragmentId: string = '';
  
  /**
   * EPUB书籍下一章节的fragmentId
   * 功能：EPUB格式书籍中下一章节的片段标识符
   * 使用场景：EPUB阅读器章节跳转
   * 默认值：空字符串
   */
  endFragmentId: string = '';
  
  /**
   * 变量
   * 功能：存储章节相关的自定义变量或扩展信息
   * 使用场景：扩展功能，如自定义解析规则、特殊处理标记等
   * 默认值：空字符串
   */
  variable: string = '';
}
