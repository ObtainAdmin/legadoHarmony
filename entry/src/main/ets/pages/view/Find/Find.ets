/**
 * @author 2008
 * @datetime 2024/6/26 23:55
 * @className: Find
 * @description: 发现页面入口组件 - 整个发现模块的根容器
 * 
 * 组件功能：
 * 1. 作为发现模块的入口点，提供统一的容器环境
 * 2. 设置全局背景色，确保视觉一致性
 * 3. 承载主要的发现页面内容（IndexFind组件）
 * 
 * 设计特点：
 * - 极简设计：只负责容器环境设置，具体逻辑由子组件处理
 * - 统一背景：使用应用级背景色，确保整体视觉协调
 * - 响应式容器：Column布局自动适应不同屏幕尺寸
 * 
 * 组件关系：
 * - 父组件：应用主框架
 * - 子组件：IndexFind（发现页面主组件）
 * 
 * 技术说明：
 * - 使用@ComponentV2装饰器：采用HarmonyOS新一代组件模型
 * - @Preview装饰器：支持开发工具实时预览
 * - 背景色使用资源引用：便于主题切换和统一管理
 */

// 导入发现页面主组件
import IndexFind from './IndexFind'

/**
 * 发现页面入口组件
 * 负责提供发现模块的根级容器环境
 */
@ComponentV2  // 使用HarmonyOS V2组件模型
@Preview      // 支持预览功能
export default struct Find {

  /**
   * 组件UI构建方法
   * 构建发现页面的根级容器
   * 
   * 布局逻辑：
   * 1. Column容器：垂直布局，自适应子组件内容
   * 2. 背景色设置：使用应用定义的背景色资源
   * 3. 内容承载：嵌入IndexFind组件提供具体功能
   * 
   * 样式说明：
   * - 背景色：使用资源引用的深灰色背景
   * - 布局：简单的垂直排列，无额外间距设置
   * - 尺寸：自动适应父容器和子组件内容
   * 
   * 扩展性：
   * - 可在此层级添加全局状态管理
   * - 可扩展为支持多页面切换的容器
   * - 背景色可响应主题变化动态调整
   */
  build() {
    Column() {
      // 嵌入发现页面主组件
      // 所有具体功能和交互逻辑都由IndexFind组件处理
      IndexFind()
    }
    // 设置统一的背景色，确保视觉一致性
    // 使用资源引用便于主题管理和统一调整
    .backgroundColor($r('app.string.color_black_88'))
  }
}